{
  "services": [
    {
      "type": "web",
      "name": "coil-calculator-frontend",
      "env": "node",
      "buildCommand": "npm run build",
      "startCommand": "npm start",
      "plan": "free",
      "envVars": [
        {
          "key": "REACT_APP_API_URL",
          "value": "https://coil-calculator-api.onrender.com"
        }
      ]
    },
    {
      "type": "web",
      "name": "coil-calculator-api",
      "env": "node",
      "dir": "backend",
      "buildCommand": "npm install",
      "startCommand": "npm start",
      "plan": "free",
      "envVars": [
        {
          "key": "PORT",
          "value": "5000"
        },
        {
          "key": "NODE_ENV",
          "value": "production"
        }
      ]
    }
  ]
}
